-- CREACIÓN DE LA BASE DE DATOS

DROP SCHEMA IF EXISTS tienda_bd;
CREATE SCHEMA tienda_bd;
USE tienda_bd;


CREATE TABLE usuarios (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    edad INT,
    telefono INT,
    rol ENUM('root', 'cliente') DEFAULT 'cliente'
) ENGINE=InnoDB;


CREATE TABLE vendedores (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(100) NOT NULL,
    logo VARCHAR(255)
) ENGINE=InnoDB;


CREATE TABLE pedidos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    fecha DATE NOT NULL,
    id_usuario INT NOT NULL,
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id) ON DELETE CASCADE
) ENGINE=InnoDB;


CREATE TABLE pagos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    id_pedido INT NOT NULL UNIQUE,
    importe FLOAT NOT NULL,
    metodo_pago ENUM('Bizum', 'Tarjeta', 'Paypal') NOT NULL,
    bizum_telefono VARCHAR(20),
    tarjeta_numero VARCHAR(20),
    tarjeta_titular VARCHAR(100),
    tarjeta_cvv INT,
    paypal_email VARCHAR(100),
    FOREIGN KEY (id_pedido) REFERENCES pedidos(id) ON DELETE CASCADE
) ENGINE=InnoDB;


CREATE TABLE productos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(150) NOT NULL,
    tipo VARCHAR(50),
    estado VARCHAR(50),
    imagen VARCHAR(255),
    precio FLOAT NOT NULL,
    zona VARCHAR(100),
    enlace VARCHAR(255),
    id_pedido INT NULL,
    FOREIGN KEY (id_pedido) REFERENCES pedidos(id) ON DELETE SET NULL
) ENGINE=InnoDB;


CREATE TABLE usuario_busca_producto (
    id_usuario INT NOT NULL,
    id_producto INT NOT NULL,
    PRIMARY KEY (id_usuario, id_producto),
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id) ON DELETE CASCADE,
    FOREIGN KEY (id_producto) REFERENCES productos(id) ON DELETE CASCADE
) ENGINE=InnoDB;


CREATE TABLE vendedor_producto (
    id_vendedor INT NOT NULL,
    id_producto INT NOT NULL,
    PRIMARY KEY (id_vendedor, id_producto),
    FOREIGN KEY (id_vendedor) REFERENCES vendedores(id) ON DELETE CASCADE,
    FOREIGN KEY (id_producto) REFERENCES productos(id) ON DELETE CASCADE
) ENGINE=InnoDB;



